<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="rover">
  <xacro:property name="mesh_dir" value="package://rover_description/meshes"/>
  <material name="body_color">
    <color rgba="0.615686 0.811765 0.929412 1"/>
  </material>

  <!-- Robot body -->
  <link name="base_link"/>
  <link name="main_body">
    <inertial>
      <origin xyz="-0.077841 0.00218182 -0.0645442" rpy="0 0 0"/>
      <mass value="0.00344468"/>
      <inertia ixx="8.31262e-06" ixy="1.21351e-08" ixz="-4.30308e-07"
               iyy="2.83262e-05" iyz="7.87963e-09" izz="3.34903e-05"/>
    </inertial>
    <visual>
      <origin xyz="8.67362e-19 0.00232656 -0.028" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_dir}/59.stl" scale="1 1 1"/>
      </geometry>
      <material name="body_color"/>
    </visual>
    <collision>
      <origin xyz="8.67362e-19 0.00232656 -0.028" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_dir}/59.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_to_body" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="main_body"/>
  </joint>

  <!-- Wheel macro -->
  <xacro:macro name="wheel" params="name xyz rpy axis inertial_xyz visual_xyz">
    <link name="${name}">
      <inertial>
        <origin xyz="${inertial_xyz}" rpy="0 0 0"/>
        <mass value="0.000126179"/>
        <inertia ixx="1.35094e-07" ixy="0" ixz="4.8002e-11"
                 iyy="7.41754e-08" iyz="0" izz="7.43953e-08"/>
      </inertial>
      <visual>
        <origin xyz="${visual_xyz}" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${mesh_dir}/63.stl" scale="1 1 1"/>
        </geometry>
        <material name="body_color"/>
      </visual>
      <collision>
        <origin xyz="${visual_xyz}" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${mesh_dir}/63.stl" scale="1 1 1"/>
        </geometry>
      </collision>
    </link>
    <joint name="${name}_joint" type="continuous">
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <axis xyz="${axis}"/>
      <parent link="main_body"/>
      <child link="${name}"/>
    </joint>
    <gazebo reference="${name}">
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
      <kp>100000.0</kp>
      <kd>1.0</kd>
    </gazebo>
  </xacro:macro>

  <!-- Wheels  -->
  <xacro:wheel
      name="wheel_2"
      xyz="-0.165821 -0.109219 -0.0805"
      rpy="0.998696 0 1.5708"
      axis="-1 0 0"
      inertial_xyz="0.0143801 0 -0.00317342"
      visual_xyz="0.001 0 0"/>

  <xacro:wheel
      name="wheel_1"
      xyz="-5.55112e-17 -0.109219 -0.0805"
      rpy="-3.13848 0 1.5708"
      axis="-1 0 0"
      inertial_xyz="0.0143801 0 -0.00317342"
      visual_xyz="0.001 0 0"/>

  <xacro:wheel
      name="wheel"
      xyz="-5.55112e-17 0.113673 -0.0805"
      rpy="0.0299318 0 -1.5708"
      axis="1 0 0"
      inertial_xyz="0.0133801 0 -0.00317342"
      visual_xyz="0 0 0"/>

  <xacro:wheel
      name="wheel_3"
      xyz="-0.165821 0.113673 -0.0805"
      rpy="0.81533 0 -1.5708"
      axis="1 0 0"
      inertial_xyz="0.0133801 0 -0.00317342"
      visual_xyz="0 0 0"/>

  <!-- Lidar sensor link -->
  <link name="lidar_link">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00007" ixy="0.0" ixz="0.0"
               iyy="0.00007" iyz="0.0"
               izz="0.00006"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
      <material name="body_color"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="main_body"/>
    <child link="lidar_link"/>
    <origin xyz="-0.08 0.0 0.02" rpy="0 0 0"/>
  </joint>

  <!-- Camera link -->
  <!-- Front facing camera for gem detection -->
  <link name="camera_link">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00002" ixy="0.0" ixz="0.0"
               iyy="0.00002" iyz="0.0"
               izz="0.00002"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
      <material name="body_color"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
    </collision>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="main_body"/>
    <child link="camera_link"/>
    <origin xyz="-0.04 0.0 0.01" rpy="0 0 0"/>
  </joint>

  <!-- gazebo plugins -->

  <!-- Differential drive plugin -->
  <!-- Allows the robot to move by subscribing to /cmd_vel -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>wheel_2_joint</left_joint>
      <left_joint>wheel_3_joint</left_joint>
      <right_joint>wheel_1_joint</right_joint>
      <right_joint>wheel_joint</right_joint>
      <wheel_separation>0.22</wheel_separation>
      <wheel_radius>0.04</wheel_radius>
      <max_linear_velocity>0.5</max_linear_velocity>
      <max_angular_velocity>1.0</max_angular_velocity>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>
  </gazebo>

  <!-- Joint state publisher plugin -->
  <!-- Publishes the state of all joints -->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
    </plugin>
  </gazebo>

  <!-- LIDAR sensor plugin -->
  <!-- Gives the robot 360 degree wall detection -->
  <gazebo reference="lidar_link">
    <sensor name="lidar" type="gpu_lidar">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <topic>scan</topic>
      <gz_frame_id>lidar_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
    </sensor>
  </gazebo>

  <!-- Camera sensor plugin -->
  <!-- Front facing camera for gem colour detection -->
  <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>30</update_rate>
      <topic>camera/image_raw</topic>
      <gz_frame_id>camera_link</gz_frame_id>
      <camera>
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>

</robot>