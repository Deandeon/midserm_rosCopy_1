<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="rover">

  <xacro:arg name="use_sim" default="true"/>
  <xacro:arg name="enable_lidar" default="true"/>
  <xacro:arg name="enable_camera" default="false"/>

  <!-- Tune these from the real CAD / world -->
  <xacro:property name="mesh_dir" value="package://rover_description/meshes"/>
  <xacro:property name="wheel_separation" value="0.223"/>
  <xacro:property name="wheel_diameter" value="0.060"/>
  <xacro:property name="body_height_estimate" value="0.215"/>
  <xacro:property name="lidar_z" value="0.185"/>
  <xacro:property name="camera_z" value="0.175"/>

  <material name="body_color">
    <color rgba="0.615686 0.811765 0.929412 1"/>
  </material>

  <link name="base_link"/>

  <link name="main_body">
    <inertial>
      <origin xyz="-0.077841 0.00218182 -0.0645442" rpy="0 0 0"/>
      <mass value="0.00344468"/>
      <inertia
        ixx="8.31262e-06" ixy="1.21351e-08" ixz="-4.30308e-07"
        iyy="2.83262e-05" iyz="7.87963e-09" izz="3.34903e-05"/>
    </inertial>

    <visual>
      <origin xyz="0 0.00232656 -0.028" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_dir}/59.stl" scale="1 1 1"/>
      </geometry>
      <material name="body_color"/>
    </visual>

    <collision>
      <origin xyz="0 0.00232656 -0.028" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_dir}/59.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_to_body" type="fixed">
    <parent link="base_link"/>
    <child link="main_body"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <xacro:macro name="wheel" params="name xyz rpy axis inertial_xyz visual_xyz friction:=1.0">
    <link name="${name}">
      <inertial>
        <origin xyz="${inertial_xyz}" rpy="0 0 0"/>
        <mass value="0.000126179"/>
        <inertia
          ixx="1.35094e-07" ixy="0" ixz="4.8002e-11"
          iyy="7.41754e-08" iyz="0" izz="7.43953e-08"/>
      </inertial>

      <visual>
        <origin xyz="${visual_xyz}" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${mesh_dir}/63.stl" scale="1 1 1"/>
        </geometry>
        <material name="body_color"/>
      </visual>

      <collision>
        <origin xyz="${visual_xyz}" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${mesh_dir}/63.stl" scale="1 1 1"/>
        </geometry>
      </collision>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="main_body"/>
      <child link="${name}"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <axis xyz="${axis}"/>
    </joint>

    <gazebo reference="${name}">
      <mu1>${friction}</mu1>
      <mu2>${friction}</mu2>
      <kp>100000.0</kp>
      <kd>1.0</kd>
      <material>Gazebo/Blue</material>
    </gazebo>
  </xacro:macro>

  <!-- y<0 side -->
  <xacro:wheel
    name="right_rear_wheel"
    xyz="-0.165821 -0.109219 -0.0805"
    rpy="0.998696 0 1.5708"
    axis="-1 0 0"
    inertial_xyz="0.0143801 0 -0.00317342"
    visual_xyz="0.001 0 0"/>

  <xacro:wheel
    name="right_front_wheel"
    xyz="0.0 -0.109219 -0.0805"
    rpy="-3.13848 0 1.5708"
    axis="-1 0 0"
    inertial_xyz="0.0143801 0 -0.00317342"
    visual_xyz="0.001 0 0"/>

  <!-- y>0 side -->
  <xacro:wheel
    name="left_front_wheel"
    xyz="0.0 0.113673 -0.0805"
    rpy="0.0299318 0 -1.5708"
    axis="1 0 0"
    inertial_xyz="0.0133801 0 -0.00317342"
    visual_xyz="0 0 0"/>

  <xacro:wheel
    name="left_rear_wheel"
    xyz="-0.165821 0.113673 -0.0805"
    rpy="0.81533 0 -1.5708"
    axis="1 0 0"
    inertial_xyz="0.0133801 0 -0.00317342"
    visual_xyz="0 0 0"/>

  <!-- Lidar -->
  <xacro:if value="$(arg enable_lidar)">
    <link name="lidar_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.02"/>
        <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.025" length="0.02"/>
        </geometry>
        <material name="body_color"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.025" length="0.02"/>
        </geometry>
      </collision>
    </link>

    <joint name="lidar_joint" type="fixed">
      <parent link="base_link"/>
      <child link="lidar_link"/>
      <origin xyz="-0.08 0 ${lidar_z}" rpy="0 0 0"/>
    </joint>
  </xacro:if>

  <!-- Optional camera for the gem task -->
  <xacro:if value="$(arg enable_camera)">
    <link name="camera_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.02"/>
        <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/>
      </inertial>
      <visual>
        <geometry>
          <box size="0.03 0.02 0.02"/>
        </geometry>
        <material name="body_color"/>
      </visual>
      <collision>
        <geometry>
          <box size="0.03 0.02 0.02"/>
        </geometry>
      </collision>
    </link>

    <joint name="camera_joint" type="fixed">
      <parent link="base_link"/>
      <child link="camera_link"/>
      <origin xyz="0.04 0 ${camera_z}" rpy="0 0 0"/>
    </joint>
  </xacro:if>

  <xacro:if value="$(arg use_sim)">
    <!-- Diff drive plugin.
         The rear pair is actuated; the front pair behaves as passive rolling wheels. -->
    <gazebo>
      <plugin name="gazebo_ros_diff_drive" filename="libgazebo_ros_diff_drive.so">
        <ros>
          <namespace>/</namespace>
        </ros>
        <update_rate>50</update_rate>

        <left_joint>left_rear_wheel_joint</left_joint>
        <right_joint>right_rear_wheel_joint</right_joint>

        <wheel_separation>${wheel_separation}</wheel_separation>
        <wheel_diameter>${wheel_diameter}</wheel_diameter>

        <max_wheel_torque>5.0</max_wheel_torque>
        <max_wheel_acceleration>2.0</max_wheel_acceleration>

        <command_topic>cmd_vel</command_topic>

        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <publish_wheel_tf>true</publish_wheel_tf>

        <odometry_topic>odom</odometry_topic>
        <odometry_frame>odom</odometry_frame>
        <robot_base_frame>base_link</robot_base_frame>
      </plugin>
    </gazebo>

    <xacro:if value="$(arg enable_lidar)">
      <gazebo reference="lidar_link">
        <sensor name="lidar" type="ray">
          <always_on>true</always_on>
          <visualize>true</visualize>
          <update_rate>10</update_rate>
          <ray>
            <scan>
              <horizontal>
                <samples>360</samples>
                <resolution>1</resolution>
                <min_angle>-3.14159</min_angle>
                <max_angle>3.14159</max_angle>
              </horizontal>
            </scan>
            <range>
              <min>0.05</min>
              <max>5.0</max>
              <resolution>0.01</resolution>
            </range>
          </ray>
          <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
            <ros>
              <remapping>~/out:=scan</remapping>
            </ros>
            <output_type>sensor_msgs/LaserScan</output_type>
            <frame_name>lidar_link</frame_name>
          </plugin>
        </sensor>
      </gazebo>
    </xacro:if>

    <xacro:if value="$(arg enable_camera)">
      <gazebo reference="camera_link">
        <sensor name="camera" type="camera">
          <always_on>true</always_on>
          <update_rate>15</update_rate>
          <camera>
            <horizontal_fov>1.3962634</horizontal_fov>
            <image>
              <width>640</width>
              <height>480</height>
              <format>R8G8B8</format>
            </image>
            <clip>
              <near>0.02</near>
              <far>10.0</far>
            </clip>
          </camera>
          <plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
            <camera_name>front_camera</camera_name>
            <frame_name>camera_link</frame_name>
          </plugin>
        </sensor>
      </gazebo>
    </xacro:if>
  </xacro:if>
</robot>
